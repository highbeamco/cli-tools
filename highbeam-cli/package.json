    "tsc-alias": "^1.8.16",
    "typescript": "^5.7.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "googleapis": "^171.4.0",
    "ky": "^1.14.3",
    "zod": "^4.3.6"
  }
